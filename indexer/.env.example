# Copy to .env. The indexer auto-loads it on startup.
#
# Most commonly overridden: LASERSTREAM_TOKEN. The rest default sanely for
# local dev. When running the indexer inside `docker compose --profile full`,
# the compose file overrides DATABASE_URL and API_BIND from this file —
# values here apply to the `cargo run` path only.

# Postgres connection string. The indexer connects as the LIMITED role
# `deep_pool_indexer` (created at first DB boot via db/02-indexer-role.sh).
# Replace <INDEXER_DB_PASSWORD> with the value you put in /.env at the repo root.
DATABASE_URL=postgres://deep_pool_indexer:<INDEXER_DB_PASSWORD>@localhost:5432/deep_pool

# Helius Laserstream endpoint + API token.
# Devnet:  https://laserstream-devnet.helius-rpc.com
# Mainnet: https://laserstream-mainnet.helius-rpc.com
LASERSTREAM_URL=https://laserstream-devnet.helius-rpc.com
LASERSTREAM_TOKEN=your-helius-api-key

# deep_pool program ID. Same address on devnet, mainnet, and localnet per
# Anchor.toml — point LASERSTREAM_URL at whichever cluster you're testing.
DEEP_POOL_PROGRAM_ID=CcwF61GW14AcxCS4E2zedHXdFXy8x8GQPvfxZrs2x2eT

# HTTP + WS bind address. Loopback-only by default: only host-local processes
# (your UI, curl, etc.) can reach it.
API_BIND=127.0.0.1:8080

# Reorg safety margin on restart. Indexer rewinds the resume slot by this
# many slots; idempotent INSERT...ON CONFLICT DO NOTHING de-dupes replayed
# events. 32 is comfortably past `finalized` on mainnet; fewer is fine on
# devnet. Set 0 to disable.
REORG_BUFFER_SLOTS=32

# Solana JSON-RPC endpoint. Used by `cargo run -- backfill` for historical
# tx walks (separate from Laserstream). Defaults to public devnet, which
# rate-limits at ~10 RPS — set BACKFILL_TX_THROTTLE_MS=100 if using it, or
# point at a Helius RPC URL for higher throughput.
RPC_URL=https://api.devnet.solana.com

# Logging filter. `deep_pool_indexer=debug` surfaces per-block / per-event traces.
RUST_LOG=deep_pool_indexer=info,sqlx=warn,tower_http=info
