# Copy to .env at repo root. Docker Compose reads this file automatically
# and interpolates values into docker-compose.yml.
#
# SECURITY: these values MUST be generated by you, not copied as-is.
# Use the two lines below to produce strong values and paste them in:
#
#   openssl rand -hex 16   # → POSTGRES_PASSWORD
#   openssl rand -hex 16   # → INDEXER_DB_PASSWORD
#
# .env is gitignored; never commit the filled-in version.

# Postgres superuser role + DB name. Used by compose, by the DB init scripts,
# and for ad-hoc ops (psql into the container). The indexer does NOT use this
# role — it has a separate least-privilege role created at first boot.
POSTGRES_USER=deep_pool
POSTGRES_DB=deep_pool
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_16
# Password for the indexer's limited-privilege DB role (deep_pool_indexer).
# This role gets SELECT/INSERT/UPDATE on our two tables only — no DDL,
# no DELETE, no access to other schemas. Password is baked into the
# indexer's DATABASE_URL at compose time.
INDEXER_DB_PASSWORD=CHANGE_ME_openssl_rand_hex_16

